# ── HOW TO USE ────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your own keys (see links below)
# 3. NEVER commit .env — it is in .gitignore

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Options: "openrouter" (default) | "gemini" | "ollama"
# LLM_BACKEND=openrouter

# OpenRouter — free tier, no credit card needed
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Recommended free models (uncomment one):
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free   ← best quality
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free           ← fastest
# OPENROUTER_MODEL=openai/gpt-oss-20b:free                   ← default

# Gemini — fallback if OpenRouter key not set
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Ollama — fully local, no key needed (requires Ollama installed)
# https://ollama.com/download
# OLLAMA_MODEL=phi3

# ── News Sources ──────────────────────────────────────────────────────────────
# NewsAPI — free tier (100 req/day)
# Get key: https://newsapi.org/register
NEWS_API_KEY=

# ── TomTom Traffic API ────────────────────────────────────────────────────────
# Real-time live incidents for Kolkata — free tier, no credit card
# Get key: https://developer.tomtom.com/how-to-get-tomtom-api-key
TOMTOM_API_KEY=

# Twitter/X — Basic plan required ($100/mo), skip for now
# TWITTER_BEARER_TOKEN=your_bearer_token_here

# ── Routing ───────────────────────────────────────────────────────────────────
# DEFAULT_CITY=Kolkata, India
# GRAPH_CACHE_PATH=cache/graph.graphml

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite:///traffic_events.db

# -- Weather-------------------------------------------------------------------

OPENWEATHER_API_KEY=
